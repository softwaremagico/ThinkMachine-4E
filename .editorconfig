root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.java]
indent_style = space
indent_size = 4
tab_width = 4

[*.xml]
indent_style = space
indent_size = 4
tab_width = 4

[*.yml]
indent_style = space
indent_size = 2
tab_width = 2

[*.properties]
indent_style = space
indent_size = 4
tab_width = 4

[*.gradle]
indent_style = space
indent_size = 4
tab_width = 4

[*.md]
indent_style = space
indent_size = 2
tab_width = 2
